{
  "name": "takoba",
  "version": "1.1.1",
  "title": "Takoba",
  "description": "Japanese dictionary, translator, and Anki integration — search Jotoba, translate sentences, add cards to Anki",
  "icon": "icon.png",
  "author": "kuro",
  "license": "MIT",
  "categories": [
    "Productivity",
    "Education"
  ],
  "commands": [
    {
      "name": "takoba",
      "title": "Takoba",
      "subtitle": "辞書 · 翻訳 · 単語帳",
      "description": "Search Jotoba for words, kanji, and sentences; add to Anki; TTS with ElevenLabs",
      "mode": "view",
      "preferences": [
        {
          "name": "ankiPort",
          "title": "AnkiConnect Port",
          "description": "Port where AnkiConnect is running",
          "type": "textfield",
          "required": false,
          "default": "8765"
        },
        {
          "name": "elevenlabsApiKey",
          "title": "ElevenLabs API Key",
          "description": "API key for ElevenLabs text-to-speech (leave empty to disable TTS)",
          "type": "password",
          "required": false,
          "default": ""
        },
        {
          "name": "elevenlabsVoiceId",
          "title": "ElevenLabs Voice ID",
          "description": "Voice ID for ElevenLabs TTS (default: 21m00Tcm4TlvDq8ikWAM — Rachel)",
          "type": "textfield",
          "required": false,
          "default": "21m00Tcm4TlvDq8ikWAM"
        },
        {
          "name": "userLanguage",
          "title": "Definition Language",
          "description": "Language for word definitions",
          "type": "dropdown",
          "required": false,
          "default": "English",
          "data": [
            {
              "title": "English",
              "value": "English"
            },
            {
              "title": "Spanish",
              "value": "Spanish"
            },
            {
              "title": "German",
