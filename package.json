    "undici": "^5.12.0"
  },
  "devDependencies": {
    "@raycast/api": "^1.104.21",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "npm run build:vicinae",
    "build:vicinae": "node scripts/copy-shim.js vicinae && vici build",
    "build:raycast": "node scripts/copy-shim.js raycast && ray build",
    "dev": "vici develop"
  }
}
