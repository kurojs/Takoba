            },
            {
              "title": "Slovenian",
              "value": "Slovenian"
            }
          ]
        },
        {
          "name": "autoLoadText",
          "title": "Auto-load selected text",
          "description": "Automatically load selected text from clipboard",
          "type": "checkbox",
          "required": false,
          "default": true
        },
        {
          "name": "geminiApiKey",
          "title": "Gemini API Key",
          "description": "API key from Google AI Studio (https://aistudio.google.com/) — required for AI explanations",
          "type": "password",
          "required": false,
          "default": ""
        },
        {
          "name": "geminiModel",
          "title": "AI Model",
          "description": "Gemini model to use for AI explanations",
          "type": "dropdown",
          "required": false,
